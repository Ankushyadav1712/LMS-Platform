# Copy to .env for local development. Values below match docker-compose.yml.
# Production values live in Vercel/Railway environment settings, never in git.

DATABASE_URL="postgresql://lms:lms@localhost:5433/lms"

# Auth — generate the secret with: openssl rand -hex 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
# Optional — login page shows the Google button only when both are set.
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Object storage (MinIO locally; Cloudflare R2 in production)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY_ID="minio"
S3_SECRET_ACCESS_KEY="minio12345"
S3_BUCKET="lms-uploads"
S3_REGION="auto"
